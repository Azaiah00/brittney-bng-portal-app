# Copy to .env and fill in your Supabase values.
# Get these from: Supabase Dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Gemini AI Key (for Smart Scratchpad, Estimator, Proposal features)
# Get from: https://aistudio.google.com/app/apikey
EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-api-key

# Google OAuth Client ID (for Google Sign-In)
# Get from: Google Cloud Console → APIs & Services → Credentials
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Server-side only (Supabase Edge Function secrets) ──
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# SIGNNOW_CLIENT_ID=your-signnow-client-id
# SIGNNOW_CLIENT_SECRET=your-signnow-client-secret
# SIGNNOW_BASE_URL=https://api-eval.signnow.com
