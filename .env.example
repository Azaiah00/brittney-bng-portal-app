# =============================================================================
# BNG Remodel Portal - environment variables
# Copy this file to .env and fill in the values from the NEW Supabase project
# (created under hello@realestateadvancement.com).
# Full setup steps: see SUPABASE_MIGRATION.md in the repo root.
# =============================================================================

# --- Supabase (NEW project: Settings -> API) ---
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-NEW-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-new-anon-public-key

# --- Gemini AI (Smart Scratchpad, Estimator, Proposals) ---
# Get from: https://aistudio.google.com/app/apikey
EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-api-key

# --- Google OAuth Client ID (Google Sign-In) ---
# Google Cloud Console -> APIs & Services -> Credentials
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# =============================================================================
# Server-side ONLY - set these as Supabase Edge Function secrets, never in the
# client .env (they must not ship in the app bundle).
# =============================================================================
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# SIGNNOW_CLIENT_ID=your-signnow-client-id
# SIGNNOW_CLIENT_SECRET=your-signnow-client-secret
# SIGNNOW_BASE_URL=https://api-eval.signnow.com
